@page "/production"
@rendermode InteractiveServer
@using FactoryAutomation.Shared
@implements IDisposable
@inject HttpClient Http

<h3>생산 현황</h3>

@if (data is null)
{
    <p>데이터를 불러오는 중입니다.</p>
}
else
{
    <p>라인: @data.LineName</p>
    <p>양품 수량: @data.GoodCount</p>
    <p>불량 수량: @data.NgCount</p>
    <p>상태: @data.Status</p>
    <p>갱신 시각: @data.CreatedAt</p>
}

@code {
    private ProductionSnapshot? data;
    private PeriodicTimer? timer;
    private CancellationTokenSource? cancellationTokenSource;

    protected override async Task OnInitializedAsync()
    {
        cancellationTokenSource = new CancellationTokenSource();
        timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        await LoadData();

        _ = StartAutoRefreshAsync(cancellationTokenSource.Token);
    }

    private async Task StartAutoRefreshAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (timer is not null &&
                   await timer.WaitForNextTickAsync(cancellationToken))
            {
                await LoadData();

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // 페이지를 벗어날 때 정상적으로 발생합니다.
        }
    }

    private async Task LoadData()
    {
        data = await Http.GetFromJsonAsync<ProductionSnapshot>("/api/production/latest");
    }

    public void Dispose()
    {
        cancellationTokenSource?.Cancel();
        cancellationTokenSource?.Dispose();
        timer?.Dispose();
    }
}